# ROOTS Environment Configuration
# Copy this file to .env and fill in the values

# AI & Language APIs
GEMINI_API_KEY=your_gemini_api_key_here
BHASHINI_API_KEY=your_bhashini_api_key_here

# Messaging APIs
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here

# Graph Database (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_PASSWORD=your_neo4j_password_here

# Relational Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://user:password@localhost:5432/roots_db
